.container {
  padding: 0 32rpx 32rpx;
  min-height: 100vh;
}

.hero {
  background: linear-gradient(135deg, #00C853, #00E676, #69F0AE);
  margin: 0 -32rpx;
  padding: 56rpx 40rpx 48rpx;
  border-radius: 0 0 40rpx 40rpx;
  margin-bottom: 36rpx;
}

.greeting {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #0F1923;
}

.hero-sub {
  display: block;
  font-size: 32rpx;
  color: rgba(15, 25, 35, 0.6);
  margin-top: 12rpx;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.stat-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 32rpx 16rpx;
  text-align: center;
  margin-right: 16rpx;
}

.stat-card:last-child {
  margin-right: 0;
}

.stat-num {
  display: block;
  font-size: 60rpx;
  font-weight: bold;
  color: #00E676;
}

.stat-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
}

/* 健康评分 */
.health-card {
  margin-bottom: 28rpx;
}

.score-area {
  display: flex;
  align-items: center;
}

.score-ring {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 8rpx solid #00E676;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 36rpx;
}

.score-num {
  font-size: 64rpx;
  font-weight: bold;
  color: #00E676;
}

.score-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: -4rpx;
}

.score-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.score-level {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.score-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.score-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-right: 12rpx;
  flex-shrink: 0;
}

.score-value {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.score-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 通用卡片 */
.card {
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 28rpx;
}

.card-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 28rpx;
}

.week-bar {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 200rpx;
  margin-bottom: 28rpx;
}

.day-col {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-bg {
  width: 56rpx;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.bar {
  width: 100%;
  min-height: 8rpx;
  background: linear-gradient(180deg, #00E676, #00C853);
  border-radius: 12rpx 12rpx 0 0;
}

.day-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
}

.day-label.today {
  color: #00E676;
  font-weight: bold;
}

.week-summary {
  text-align: center;
}

.week-total {
  font-size: 52rpx;
  font-weight: bold;
  color: #00E676;
}

.week-unit {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-left: 8rpx;
}
