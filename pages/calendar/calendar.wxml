<view class="container">
  <!-- 月份切换 -->
  <view class="month-nav">
    <view class="nav-btn" bindtap="prevMonth">
      <text class="nav-arrow">{{leftArrow}}</text>
    </view>
    <text class="month-title">{{year}} 年 {{month}} 月</text>
    <view class="nav-btn" bindtap="nextMonth">
      <text class="nav-arrow">{{rightArrow}}</text>
    </view>
  </view>

  <!-- 本月统计 -->
  <view class="month-summary">
    <view class="summary-item">
      <text class="summary-num">{{monthDays}}</text>
      <text class="summary-label">天打卡</text>
    </view>
    <view class="summary-divider"></view>
    <view class="summary-item">
      <text class="summary-num">{{monthTotal}}</text>
      <text class="summary-label">千卡</text>
    </view>
  </view>

  <!-- 星期标头 -->
  <view class="weekday-row">
    <text class="weekday" wx:for="{{weekdays}}" wx:key="*this">{{item}}</text>
  </view>

  <!-- 日历格子 -->
  <view class="calendar-grid">
    <view
      class="day-cell {{item.empty ? 'empty' : ''}} {{item.checked ? 'checked' : ''}} {{item.isToday ? 'today' : ''}}"
      wx:for="{{days}}"
      wx:key="dateStr"
    >
      <text class="day-num">{{item.day}}</text>
      <view class="day-dot" wx:if="{{item.checked}}"></view>
    </view>
  </view>
</view>
