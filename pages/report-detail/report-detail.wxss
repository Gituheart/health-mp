.container {
  padding: 32rpx;
  min-height: 100vh;
}

.images-section {
  margin-bottom: 32rpx;
}

.images-scroll {
  white-space: nowrap;
}

.report-img {
  width: 280rpx;
  height: 360rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
  display: inline-block;
}

.analysis-section {
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 32rpx;
}

.analysis-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.analysis-icon {
  font-size: 44rpx;
}

.analysis-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #00E676;
}

.analysis-content {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 2;
}

.disclaimer {
  background: rgba(255, 152, 0, 0.1);
  border: 2rpx solid rgba(255, 152, 0, 0.2);
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 48rpx;
}

.disclaimer-text {
  font-size: 28rpx;
  color: #FFB74D;
  line-height: 1.8;
}

.loading {
  text-align: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.4);
}
