.container {
  padding: 48rpx 32rpx;
  min-height: 100vh;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 40rpx;
}

.loading {
  text-align: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* ========== 无群状态：大块上下 ========== */
.empty-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 40rpx 0 64rpx;
}

.hero-icon {
  font-size: 120rpx;
}

.hero-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 20rpx;
}

.big-action-col {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.big-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 32rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.big-action-btn.create {
  background: rgba(0, 230, 118, 0.08);
  border-color: rgba(0, 230, 118, 0.25);
}

.big-action-btn.join {
  background: rgba(255, 109, 0, 0.08);
  border-color: rgba(255, 109, 0, 0.25);
}

.big-action-icon {
  font-size: 72rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.big-action-btn.create .big-action-icon {
  color: #00E676;
}

.big-action-btn.join .big-action-icon {
  color: #FF9100;
}

.big-action-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.big-action-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* ========== 有群状态：顶部小按钮左右 ========== */
.small-action-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.small-action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.small-action-btn.create {
  background: rgba(0, 230, 118, 0.08);
  border-color: rgba(0, 230, 118, 0.2);
}

.small-action-btn.join {
  background: rgba(255, 109, 0, 0.08);
  border-color: rgba(255, 109, 0, 0.2);
}

.small-action-icon {
  font-size: 36rpx;
  font-weight: bold;
}

.small-action-btn.create .small-action-icon {
  color: #00E676;
}

.small-action-btn.join .small-action-icon {
  color: #FF9100;
}

.small-action-label {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 分享提示 */
.share-tip {
  background: rgba(0, 230, 118, 0.1);
  border: 2rpx solid rgba(0, 230, 118, 0.2);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 28rpx;
  text-align: center;
}

.share-tip-text {
  font-size: 26rpx;
  color: #00E676;
}

/* ========== 群列表 ========== */
.section {
  margin-bottom: 48rpx;
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 28rpx;
}

.group-card {
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.group-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.group-members {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.group-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.group-arrow {
  font-size: 28rpx;
  color: #00E676;
}

.group-share-btn {
  background: rgba(0, 230, 118, 0.15) !important;
  color: #00E676 !important;
  font-size: 26rpx !important;
  font-weight: bold !important;
  border-radius: 10rpx !important;
  padding: 10rpx 28rpx !important;
  line-height: 1.8 !important;
  border: 2rpx solid rgba(0, 230, 118, 0.3) !important;
  min-height: 0 !important;
}

/* ========== 弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 600rpx;
  background: #1A2A38;
  border-radius: 24rpx;
  padding: 48rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-input {
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  padding: 24rpx;
  color: #fff;
  font-size: 30rpx;
  margin-bottom: 40rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.modal-btn.cancel {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.6);
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #00E676, #00C853);
  color: #0F1923;
}
