.container {
  padding: 48rpx 32rpx;
  min-height: 100vh;
}

.loading {
  text-align: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 群组头部 */
.group-header-card {
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 32rpx;
}

.group-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.group-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.member-count {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.group-actions {
  display: flex;
  justify-content: flex-end;
}

.copy-id {
  font-size: 26rpx;
  color: #00E676;
  padding: 8rpx 20rpx;
  border: 2rpx solid rgba(0, 230, 118, 0.3);
  border-radius: 8rpx;
}

/* 周期切换 */
.period-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 16rpx;
}

.period-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
}

.period-tab.active {
  background: rgba(0, 230, 118, 0.2);
}

.period-label {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.5);
}

.period-tab.active .period-label {
  color: #00E676;
  font-weight: bold;
}

.period-range {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.3);
  text-align: center;
  margin-bottom: 36rpx;
}

/* 排行榜 */
.leaderboard {
  margin-bottom: 48rpx;
  transition: opacity 0.15s;
}

.leaderboard.is-refreshing {
  opacity: 0.5;
}

.leaderboard-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.04);
  border: 2rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
}

.rank-item.is-me {
  background: rgba(0, 230, 118, 0.08);
  border-color: rgba(0, 230, 118, 0.2);
}

.rank-num {
  width: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rank-medal {
  font-size: 48rpx;
}

.rank-number {
  font-size: 36rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.4);
}

.rank-user {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.rank-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00E676, #00C853);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #0F1923;
  line-height: 80rpx;
  text-align: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.rank-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.rank-name {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.85);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-me-tag {
  background: rgba(0, 230, 118, 0.2);
  color: #00E676;
  font-size: 22rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.rank-stats {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.rank-cal {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.rank-days {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 6rpx;
}

.empty-rank {
  text-align: center;
  padding: 80rpx 0;
}

.empty-rank-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.3);
}

.invite-btn {
  background: linear-gradient(135deg, #00E676, #00C853) !important;
  color: #0F1923 !important;
  font-size: 34rpx !important;
  font-weight: bold !important;
  border-radius: 16rpx !important;
  padding: 28rpx !important;
  border: none !important;
  line-height: 1.8 !important;
}

.quit-row {
  text-align: center;
  padding: 32rpx 0 48rpx;
}

.quit-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.3);
}
