.container {
  padding: 48rpx 32rpx;
  min-height: 100vh;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.page-desc {
  display: block;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 12rpx;
  margin-bottom: 40rpx;
}

.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 320rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 4rpx dashed rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  margin-bottom: 32rpx;
}

.upload-icon {
  font-size: 88rpx;
  color: #00E676;
  line-height: 1;
}

.upload-text {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 16rpx;
}

.upload-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.3);
  margin-top: 12rpx;
}

.preview-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.preview-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.preview-del {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 56rpx;
  height: 56rpx;
  background: #FF5252;
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 56rpx;
  font-size: 32rpx;
}

.preview-add {
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 4rpx dashed rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: rgba(255, 255, 255, 0.3);
  line-height: 200rpx;
  text-align: center;
}

.submit-btn {
  background: linear-gradient(135deg, #00E676, #00C853);
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 48rpx;
}

.submit-btn.disabled {
  opacity: 0.3;
}

.submit-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #0F1923;
}

.section {
  margin-top: 16rpx;
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 24rpx;
}

.report-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 28rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.report-date {
  font-size: 34rpx;
  color: #fff;
  font-weight: bold;
}

.report-count {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
}

.report-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.3);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 160rpx;
}

.empty-icon {
  font-size: 96rpx;
}

.empty-text {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.3);
  margin-top: 28rpx;
}
