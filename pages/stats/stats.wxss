.container {
  padding: 48rpx 32rpx;
  min-height: 100vh;
}

.loading {
  text-align: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.4);
}

.stats-card {
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 24rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.stat-num.green {
  color: #00E676;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
}

/* 运动排行 */
.exercise-list {
  display: flex;
  flex-direction: column;
}

.exercise-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.05);
}

.exercise-item:last-child {
  border-bottom: none;
}

.exercise-rank {
  width: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.3);
}

.exercise-name {
  flex: 1;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
}

.exercise-count {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-right: 24rpx;
}

.exercise-cal {
  font-size: 28rpx;
  font-weight: bold;
  color: #00E676;
}
