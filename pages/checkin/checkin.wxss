.container {
  padding: 32rpx;
  min-height: 100vh;
}

/* 连续打卡 */
.streak-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 109, 0, 0.1);
  border: 2rpx solid rgba(255, 109, 0, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 32rpx;
}

.streak-fire {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.streak-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #FF9100;
}

.section {
  margin-bottom: 48rpx;
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 28rpx;
}

/* 运动类型 - 一排两个 */
.type-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.type-item {
  display: flex;
  align-items: center;
  width: 332rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  box-sizing: border-box;
}

.type-item.active {
  background: rgba(0, 230, 118, 0.15);
  border-color: #00E676;
  box-shadow: 0 0 20rpx rgba(0, 230, 118, 0.2);
}

.type-emoji {
  font-size: 44rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.type-name {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.7);
  flex: 1;
}

.type-met {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}

.type-item.active .type-name {
  color: #00E676;
  font-weight: bold;
}

.type-item.active .type-met {
  color: rgba(0, 230, 118, 0.6);
}

/* 时长 - 大按钮 */
.duration-row {
  display: flex;
  gap: 16rpx;
}

.duration-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
}

.duration-btn.active {
  background: rgba(0, 230, 118, 0.15);
  border-color: #00E676;
  color: #00E676;
  font-weight: bold;
}

.custom-input-row {
  margin-top: 20rpx;
}

.custom-input {
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 34rpx;
  color: #fff;
}

/* 卡路里圆环 */
.calorie-ring {
  display: flex;
  justify-content: center;
  margin: 48rpx 0;
}

.ring-inner {
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 230, 118, 0.1) 0%, transparent 70%);
  border: 6rpx solid #00E676;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 40rpx rgba(0, 230, 118, 0.3);
}

.calorie-num {
  font-size: 68rpx;
  font-weight: bold;
  color: #00E676;
}

.calorie-unit {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 提交按钮 */
.submit-btn {
  background: linear-gradient(135deg, #00E676, #00C853);
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 48rpx;
}

.submit-btn.disabled {
  opacity: 0.3;
}

.submit-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #0F1923;
}

/* 记录 */
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.record-type {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

.record-time {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
}

.record-cal {
  font-size: 34rpx;
  color: #00E676;
  font-weight: bold;
}
