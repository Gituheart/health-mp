<view class="container">
  <text class="page-title">我的</text>

  <view class="profile-card" wx:if="{{userInfo}}" bindtap="goUserInfo">
    <view class="avatar">{{userInfo.nickname[0] || '?'}}</view>
    <view class="profile-info">
      <text class="profile-name">{{userInfo.nickname}}</text>
      <text class="profile-meta">{{userInfo.age}}岁 · {{userInfo.height ? userInfo.height + 'cm · ' : ''}}{{userInfo.weight}}kg</text>
    </view>
    <text class="menu-arrow">{{arrow}}</text>
  </view>

  <!-- 身体数据 -->
  <view class="body-data" wx:if="{{bmi}}">
    <view class="body-item">
      <text class="body-value">{{bmi}}</text>
      <text class="body-label">BMI</text>
      <text class="body-tag">{{bmiLabel}}</text>
    </view>
    <view class="body-divider"></view>
    <view class="body-item" wx:if="{{bodyFat}}">
      <text class="body-value">{{bodyFat}}</text>
      <text class="body-label">体脂率</text>
      <text class="body-tag">{{bodyFatLevel}}</text>
    </view>
    <view class="body-item" wx:if="{{!bodyFat}}">
      <text class="body-hint">填写性别可计算体脂率</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goReport">
      <text class="menu-icon">📋</text>
      <text class="menu-text">我的体检报告</text>
      <text class="menu-arrow">{{arrow}}</text>
    </view>
    <view class="menu-item" bindtap="goCalendar">
      <text class="menu-icon">📅</text>
      <text class="menu-text">打卡日历</text>
      <text class="menu-arrow">{{arrow}}</text>
    </view>
    <view class="menu-item" bindtap="goStats">
      <text class="menu-icon">📊</text>
      <text class="menu-text">运动统计</text>
      <text class="menu-arrow">{{arrow}}</text>
    </view>
  </view>
</view>
