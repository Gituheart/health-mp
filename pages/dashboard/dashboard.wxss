.container {
  padding: 32rpx;
  min-height: 100vh;
}

.loading {
  text-align: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 今日状态卡片 */
.today-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  border: 2rpx solid transparent;
}

.today-card.checked {
  background: rgba(0, 230, 118, 0.1);
  border-color: rgba(0, 230, 118, 0.25);
}

.today-card.missed {
  background: rgba(255, 77, 79, 0.1);
  border-color: rgba(255, 77, 79, 0.25);
}

.today-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.today-icon {
  font-size: 56rpx;
}

.today-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.today-sub {
  display: block;
  font-size: 28rpx;
  margin-top: 6rpx;
}

.today-card.checked .today-sub {
  color: #00E676;
}

.today-card.missed .today-sub {
  color: #FF4D4F;
}

.today-streak {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF9100;
}

/* 本周汇总 */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.stat-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 32rpx 16rpx;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 52rpx;
  font-weight: bold;
  color: #00E676;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
}

/* 柱状图 */
.chart-section {
  background: rgba(255, 255, 255, 0.04);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 40rpx 32rpx 32rpx;
}

.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 40rpx;
}

.bar-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 280rpx;
  padding-bottom: 0;
}

.bar-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 240rpx;
  width: 100%;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.bar-cal {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 6rpx;
  text-align: center;
}

.bar {
  width: 100%;
  border-radius: 8rpx 8rpx 4rpx 4rpx;
  min-height: 8rpx;
  transition: height 0.3s;
}

.bar-active {
  background: linear-gradient(to top, #00C853, #00E676);
}

.bar-empty {
  background: rgba(255, 77, 79, 0.2);
  border: 2rpx solid rgba(255, 77, 79, 0.3);
}

.bar-today.bar-active {
  background: linear-gradient(to top, #00B0FF, #40C4FF);
  box-shadow: 0 0 16rpx rgba(64, 196, 255, 0.4);
}

.bar-today.bar-empty {
  background: rgba(255, 77, 79, 0.35);
  border-color: #FF4D4F;
}

.bar-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 12rpx;
}

.bar-label-today {
  color: #40C4FF;
  font-weight: bold;
}

/* 图例 */
.chart-legend {
  display: flex;
  gap: 32rpx;
  margin-top: 32rpx;
  justify-content: flex-end;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
}

.legend-dot.active {
  background: #00E676;
}

.legend-dot.missed {
  background: rgba(255, 77, 79, 0.5);
  border: 2rpx solid rgba(255, 77, 79, 0.6);
}

.legend-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}
