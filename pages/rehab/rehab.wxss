.container {
  padding: 32rpx 32rpx 200rpx;
  min-height: 100vh;
}

/* 头部进度 */
.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.progress-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.progress-sub {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 6rpx;
}

.progress-circle {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  border: 6rpx solid #00E676;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.progress-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #00E676;
}

.progress-total {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 免责提示 */
.disclaimer-bar {
  background: rgba(255, 193, 7, 0.1);
  border: 2rpx solid rgba(255, 193, 7, 0.2);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 32rpx;
}

.disclaimer-text {
  font-size: 26rpx;
  color: rgba(255, 193, 7, 0.9);
  line-height: 1.6;
}

/* 动作卡片 */
.exercise-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.exercise-card {
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  overflow: hidden;
  transition: border-color 0.2s;
}

.exercise-card.done {
  border-color: rgba(0, 230, 118, 0.4);
  background: rgba(0, 230, 118, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
}

.card-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ex-emoji {
  font-size: 56rpx;
  flex-shrink: 0;
}

.ex-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.ex-target {
  display: block;
  font-size: 24rpx;
  color: rgba(0, 230, 118, 0.8);
  margin-top: 4rpx;
}

.card-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.ex-done-tag {
  font-size: 32rpx;
  color: #00E676;
  font-weight: bold;
}

.expand-icon {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 处方行 */
.prescription-row {
  padding: 0 32rpx 20rpx;
}

.prescription-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 展开内容 */
.card-body {
  padding: 0 32rpx 20rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.06);
  margin-top: 4rpx;
  padding-top: 24rpx;
}

.steps-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 16rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.step-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 230, 118, 0.15);
  color: #00E676;
  font-size: 24rpx;
  font-weight: bold;
  text-align: center;
  line-height: 40rpx;
  flex-shrink: 0;
}

.step-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
  flex: 1;
}

.caution-row {
  background: rgba(255, 77, 79, 0.08);
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  margin-top: 16rpx;
}

.caution-text {
  font-size: 26rpx;
  color: rgba(255, 120, 120, 0.9);
  line-height: 1.6;
}

/* 完成按钮 */
.done-btn {
  margin: 0 32rpx 28rpx;
  padding: 24rpx;
  text-align: center;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.done-btn.done-active {
  background: rgba(0, 230, 118, 0.12);
  border-color: rgba(0, 230, 118, 0.3);
}

.done-btn-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: bold;
}

.done-btn.done-active .done-btn-text {
  color: #00E676;
}

/* 底部打卡栏 */
.checkin-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: #0F1923;
  border-top: 2rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.checkin-summary {
  flex: 1;
}

.checkin-summary-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.5);
}

.checkin-btn {
  background: linear-gradient(135deg, #00E676, #00C853);
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
}

.checkin-btn-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #0F1923;
}

/* 时长弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-content {
  width: 100%;
  background: #1A2430;
  border-radius: 24rpx 24rpx 0 0;
  padding: 48rpx 32rpx 80rpx;
}

.modal-title {
  display: block;
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 40rpx;
  text-align: center;
}

.duration-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.duration-opt {
  flex: 1;
  min-width: 180rpx;
  text-align: center;
  padding: 28rpx 0;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.7);
}

.duration-opt.active {
  background: rgba(0, 230, 118, 0.15);
  border-color: #00E676;
  color: #00E676;
  font-weight: bold;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 32rpx;
  border-radius: 16rpx;
  font-size: 34rpx;
  font-weight: bold;
}

.modal-btn.cancel {
  background: rgba(255, 255, 255, 0.06);
  color: rgba(255, 255, 255, 0.5);
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #00E676, #00C853);
  color: #0F1923;
}

.modal-btn.disabled {
  opacity: 0.5;
}
